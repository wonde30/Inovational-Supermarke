<template>
  <div class="min-h-screen bg-gradient-to-br from-green-50 via-emerald-50 to-teal-50 relative overflow-hidden">
    <!-- Decorative Background -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute -top-40 -right-40 w-96 h-96 bg-green-200/30 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-emerald-200/30 rounded-full blur-3xl"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-teal-100/20 rounded-full blur-3xl"></div>
    </div>

    <div class="relative z-10 p-6">
      <div class="space-y-6">
        <!-- Modern Header -->
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
          <div class="flex-1 max-w-md">
            <div class="relative">
              <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-xl">🔍</span>
              <input 
                v-model="search" 
                @input="fetchProducts" 
                type="text"
                class="w-full pl-12 pr-4 py-3 border-2 border-gray-200 rounded-xl focus:border-green-500 focus:ring-4 focus:ring-green-100 transition-all outline-none font-medium bg-white shadow-sm" 
                placeholder="Search products..."
              />
            </div>
          </div>
          <button @click="openModal()" class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-700 hover:to-emerald-700 text-white font-bold rounded-xl shadow-lg hover:shadow-xl transition-all hover:-translate-y-0.5">
            <span class="text-xl">➕</span>
            <span>Add Product</span>
          </button>
        </div>

      <!-- Loading State -->
      <div v-if="loading" class="flex justify-center py-16">
        <div class="loading-spinner w-12 h-12"></div>
      </div>

      <!-- Modern Products Table -->
      <div v-else class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-gradient-to-r from-green-600 to-emerald-600 text-white">
              <tr>
                <th class="px-6 py-4 text-left text-sm font-bold">Product</th>
                <th class="px-6 py-4 text-left text-sm font-bold">SKU</th>
                <th class="px-6 py-4 text-left text-sm font-bold">Category</th>
                <th class="px-6 py-4 text-left text-sm font-bold">Price (ETB)</th>
                <th class="px-6 py-4 text-left text-sm font-bold">Stock</th>
                <th class="px-6 py-4 text-left text-sm font-bold">Status</th>
                <th class="px-6 py-4 text-left text-sm font-bold">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <tr v-for="product in products" :key="product.id" class="hover:bg-green-50 transition-colors">
                <td class="px-6 py-4">
                  <div class="flex items-center gap-3">
                    <div class="w-12 h-12 bg-gradient-to-br from-green-50 to-emerald-50 rounded-xl flex items-center justify-center overflow-hidden border border-green-100">
                      <img 
                        :src="getImageUrl(product.image)" 
                        :alt="product.name"
                        class="w-full h-full object-contain p-1"
                        @error="handleImageError"
                      />
                    </div>
                    <div>
                      <p class="font-bold text-gray-800">{{ product.name }}</p>
                      <p class="text-xs text-gray-500">{{ product.category?.name || 'Uncategorized' }}</p>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4">
                  <code class="bg-gray-100 px-3 py-1 rounded-lg text-sm font-mono text-gray-700">{{ product.sku }}</code>
                </td>
                <td class="px-6 py-4">
                  <span class="px-3 py-1 bg-purple-100 text-purple-700 rounded-full text-sm font-semibold">{{ product.category?.name || 'N/A' }}</span>
                </td>
                <td class="px-6 py-4 font-bold text-green-600 text-lg">
                  ETB {{ formatCurrency(product.price) }}
                </td>
                <td class="px-6 py-4">
                  <div class="flex items-center gap-2">
                    <span :class="product.low_stock ? 'text-red-600 font-bold' : 'text-gray-700 font-semibold'">
                      {{ product.quantity }}
                    </span>
                    <span v-if="product.low_stock" class="px-2 py-0.5 bg-red-100 text-red-700 rounded-full text-xs font-bold">Low</span>
                  </div>
                </td>
                <td class="px-6 py-4">
                  <span v-if="product.quantity <= 0" class="px-3 py-1 bg-red-100 text-red-700 rounded-full text-sm font-semibold">Out of Stock</span>
                  <span v-else-if="product.low_stock" class="px-3 py-1 bg-yellow-100 text-yellow-700 rounded-full text-sm font-semibold">Low Stock</span>
                  <span v-else class="badge badge-success">In Stock</span>
                </td>
                <td class="px-6 py-4">
                <div class="flex items-center gap-2">
                  <button @click="openModal(product)" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white text-sm font-medium rounded-lg shadow-sm hover:shadow-md transition-all duration-200 transform hover:scale-105">
                    <span>✏️</span>
                    <span>Edit</span>
                  </button>
                  <button @click="deleteProduct(product.id)" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-gradient-to-r from-red-500 to-red-600 hover:from-red-600 hover:to-red-700 text-white text-sm font-medium rounded-lg shadow-sm hover:shadow-md transition-all duration-200 transform hover:scale-105">
                    <span>🗑️</span>
                    <span>Delete</span>
                  </button>
                </div>
              </td>
            </tr>
            <tr v-if="products.length === 0">
              <td colspan="7">
                <div class="empty-state">
                  <div class="empty-state-icon">📦</div>
                  <p class="empty-state-title">No products found</p>
                  <p class="empty-state-text">Add your first product to get started</p>
                </div>
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <div v-if="meta.last_page > 1" class="flex justify-center mt-6">
        <div class="pagination">
          <button 
            @click="fetchProducts(meta.current_page - 1)" 
            :disabled="meta.current_page === 1"
            class="pagination-btn"
          >
            ←
          </button>
          <template v-for="page in meta.last_page" :key="page">
            <button 
              v-if="page <= 5 || page === meta.last_page || Math.abs(page - meta.current_page) <= 1"
              @click="fetchProducts(page)"
              class="pagination-btn"
              :class="{ 'pagination-btn-active': page === meta.current_page }"
            >
              {{ page }}
            </button>
            <span v-else-if="page === 6" class="px-2 text-dark-400">...</span>
          </template>
          <button 
            @click="fetchProducts(meta.current_page + 1)" 
            :disabled="meta.current_page === meta.last_page"
            class="pagination-btn"
          >
            →
          </button>
        </div>
      </div>
    </div>

    <!-- Add/Edit Modal -->
    <Modal v-model="showModal" :title="editingProduct ? 'Edit Product / ምርት አስተካክል' : 'Add Product / ምርት ጨምር'">
      <form @submit.prevent="saveProduct" class="space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div class="col-span-2">
            <label class="form-label">Product Name / የምርት ስም</label>
            <input v-model="form.name" class="input" placeholder="Enter product name" />
          </div>
          <div>
            <label class="form-label">SKU</label>
            <input v-model="form.sku" class="input" placeholder="e.g., PROD-001" />
          </div>
          <div>
            <label class="form-label">Category</label>
            <select v-model="form.category_id" class="input">
              <option value="">Select category</option>
              <option v-for="cat in categoryOptions" :key="cat.value" :value="cat.value">
                {{ cat.label }}
              </option>
            </select>
          </div>
          <div>
            <label class="form-label">Price (ETB) / ዋጋ</label>
            <input v-model="form.price" type="number" step="0.01" class="input" placeholder="0.00" />
          </div>
          <div>
            <label class="form-label">Cost (ETB) / ወጪ</label>
            <input v-model="form.cost" type="number" step="0.01" class="input" placeholder="0.00" />
          </div>
          <div>
            <label class="form-label">Quantity / ብዛት</label>
            <input v-model="form.quantity" type="number" class="input" placeholder="0" />
          </div>
          <div>
            <label class="form-label">Reorder Level</label>
            <input v-model="form.reorder_level" type="number" class="input" placeholder="10" />
          </div>
          <div class="col-span-2">
            <label class="form-label">Image URL (Optional)</label>
            <input v-model="form.image" type="text" class="input" placeholder="https://example.com/image.jpg" />
            <p class="form-hint">Enter a URL for the product image</p>
          </div>
        </div>
        
        <div class="flex justify-end gap-3 pt-4 border-t">
          <button type="button" @click="showModal = false" class="inline-flex items-center gap-2 px-5 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold rounded-xl border border-gray-300 transition-all duration-200">
            <span>✕</span>
            <span>Cancel</span>
          </button>
          <button type="submit" class="inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-green-500 to-emerald-600 hover:from-green-600 hover:to-emerald-700 text-white font-semibold rounded-xl shadow-lg hover:shadow-xl transition-all duration-200 transform hover:scale-105">
            <span>💾</span>
            <span>{{ editingProduct ? 'Update' : 'Save' }}</span>
          </button>
        </div>
      </form>
    </Modal>
  </div>
</template>

<script setup>
import { ref, reactive, onMounted } from 'vue'
import { productsApi, categoriesApi } from '../../services/api'
import { useToastStore } from '../../stores/toast'
import Modal from '../../components/Modal.vue'

const toast = useToastStore()
const loading = ref(true)
const products = ref([])
const meta = ref({ current_page: 1, last_page: 1 })
const search = ref('')
const showModal = ref(false)
const editingProduct = ref(null)
const categoryOptions = ref([])
const form = reactive({ name: '', sku: '', price: '', cost: '', quantity: '', reorder_level: 10, category_id: '', image: '' })

const formatCurrency = (amount) => {
  return Number(amount || 0).toLocaleString('en-ET', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
}

const getImageUrl = (image) => {
  if (!image) return '/images/products/default.jpg'
  if (image.startsWith('http')) return image
  if (image.startsWith('/')) return image
  if (image.startsWith('images/')) return '/' + image
  return `/images/products/${image}`
}

const handleImageError = (e) => {
  e.target.style.display = 'none'
  e.target.parentElement.innerHTML = '<span class="text-2xl">📦</span>'
}

const getCategoryIcon = (categoryName) => {
  const icons = {
    'Electronics': '📱', 'Food': '🍞', 'Beverages': '🥤', 'Cleaning': '🧹',
    'Personal Care': '🧴', 'Office Supplies': '📎', 'Stationery': '✏️',
    'Clothing': '👕', 'Footwear': '👟', 'Home': '🏠', 'Kitchen': '🍳',
    'Sports': '⚽', 'Toys': '🧸', 'Health': '💊', 'Beauty': '💄',
    'Books': '📚', 'Grocery': '🛒',
  }
  if (!categoryName) return '📦'
  for (const [key, icon] of Object.entries(icons)) {
    if (categoryName.toLowerCase().includes(key.toLowerCase())) return icon
  }
  return '📦'
}

const fetchProducts = async (page = 1) => {
  loading.value = true
  try {
    const response = await productsApi.getAll({ page, search: search.value })
    products.value = response.data
    meta.value = response.meta
  } catch (e) {
    toast.error('Failed to load products')
  } finally {
    loading.value = false
  }
}

const fetchCategories = async () => {
  try {
    const response = await categoriesApi.getAll()
    categoryOptions.value = response.data.map(c => ({ value: c.id, label: c.name }))
  } catch (e) {}
}

const openModal = (product = null) => {
  editingProduct.value = product
  if (product) {
    Object.assign(form, product)
  } else {
    Object.assign(form, { name: '', sku: '', price: '', cost: '', quantity: '', reorder_level: 10, category_id: '', image: '' })
  }
  showModal.value = true
}

const saveProduct = async () => {
  try {
    if (editingProduct.value) {
      await productsApi.update(editingProduct.value.id, form)
      toast.success('Product updated successfully!')
    } else {
      await productsApi.create(form)
      toast.success('Product created successfully!')
    }
    showModal.value = false
    fetchProducts()
  } catch (e) {
    toast.error(e.message || 'Failed to save product')
  }
}

const deleteProduct = async (id) => {
  if (!confirm('Are you sure you want to delete this product?')) return
  try {
    await productsApi.delete(id)
    toast.success('Product deleted')
    fetchProducts()
  } catch (e) {
    toast.error('Failed to delete product')
  }
}

onMounted(() => {
  fetchProducts()
  fetchCategories()
})
</script>
