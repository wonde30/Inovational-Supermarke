                                @mouseover="newsover(index)" v-for="(item,index) in homenews" :key="index"
                                v-if="index<=2">
                                <li class="titleBox">
                                    <span class="newsTitle">{{item.title}}</span>
                                </li>
                                <li class="info">
                                    <span class="newsTime">{{item.datetime}}</span>
                                    <span class="news-subtitle" v-if="item.teaser">{{item.teaser}}</span>
                                    <span class="news-subtitle news-link" v-else></span>
                                    <a class="newsLearnMore" style="color: #0064fe;cursor: pointer;"
                                        @click="goDetail(item)" title="news title">Learn More &gt;</a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
