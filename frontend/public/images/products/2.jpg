<style>
    .row>* {
        width: auto;
        padding: unset;
    }

    .video-miniTitle text {
        cursor: pointer;
    }

    .video-miniTitle .Film {
        cursor: pointer;
    }

    .videoClose {
        cursor: pointer;
    }

    #brandBtnM {
        margin: auto;
    }

    /* 首屏视频白色进度条播放时间 */
    .HomePageBannerList .swiper-pagination-bullet-active:after {
        animation: dots 6s linear;
        animation-fill-mode: forwards
    }

    /* 首屏标题跳转的颜色 */
    .videotit_link {
        color: #fff;
    }

    .videotit_link:hover {
        color: #fff;
    }

    /* 手机端视频横屏 */
    /*.rotateVideo {*/
    /*    width: 100%;*/
    /*    transform: rotate(90deg) scale(1.5);*/
    /*}*/

    /* 当第一屏为活动时 */

    @media screen and (min-width:768px) {
        .bannerhost {
            height: fit-content;
        }
    }

    @media screen and (max-width:767px) {
        .bannerhost {
            height: fit-content;
            padding: 0;
        }
    }

    [data-device-type="pc"] .swiperpic {
        width: 100vw;
        height: 100vh;
        object-fit: cover;
    }

    [data-device-type="mobile"] .swiperpicf {
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    [data-device-type="mobile"] .swiperpicf .swiperpic {
        height: calc(100vh - 13.88vw);
        width: 100%;
        object-fit: cover;
    }
</style>
