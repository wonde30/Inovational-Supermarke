{
  "info": {
    "name": "Smart SuperMarket - Chapa Payment API",
    "description": "Complete API collection for testing Chapa payment integration",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "12345"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{auth_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api/v1",
      "type": "string"
    },
    {
      "key": "auth_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "order_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "transaction_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.data && response.data.token) {",
                  "        pm.collectionVariables.set('auth_token', response.data.token);",
                  "        console.log('Token saved:', response.data.token);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          },
          "response": []
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "2. Storefront - Checkout",
      "item": [
        {
          "name": "Complete Checkout with Chapa",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    if (response.data && response.data.order) {",
                  "        pm.collectionVariables.set('order_id', response.data.order.id);",
                  "        console.log('Order ID saved:', response.data.order.id);",
                  "    }",
                  "    if (response.data && response.data.payment) {",
                  "        pm.collectionVariables.set('transaction_id', response.data.payment.transaction_id);",
                  "        console.log('Transaction ID saved:', response.data.payment.transaction_id);",
                  "        console.log('Checkout URL:', response.data.payment.checkout_url);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"product_id\": 1,\n      \"quantity\": 2\n    },\n    {\n      \"product_id\": 2,\n      \"quantity\": 1\n    }\n  ],\n  \"payment_method\": \"chapa\",\n  \"shipping_address\": \"123 Main Street, Addis Ababa, Ethiopia\",\n  \"phone\": \"+251911234567\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/storefront/checkout",
              "host": ["{{base_url}}"],
              "path": ["storefront", "checkout"]
            },
            "description": "Create order and initialize Chapa payment in one request"
          },
          "response": []
        },
        {
          "name": "Get Products",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/storefront/products",
              "host": ["{{base_url}}"],
              "path": ["storefront", "products"]
            },
            "description": "Get available products for checkout"
          },
          "response": []
        }
      ]
    },
    {
      "name": "3. Order Management",
      "item": [
        {
          "name": "Get My Orders",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/storefront/orders",
              "host": ["{{base_url}}"],
              "path": ["storefront", "orders"]
            }
          },
          "response": []
        },
        {
          "name": "Get Order Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/storefront/orders/{{order_id}}",
              "host": ["{{base_url}}"],
              "path": ["storefront", "orders", "{{order_id}}"]
            }
          },
          "response": []
        },
        {
          "name": "Initialize Payment for Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.data) {",
                  "        pm.collectionVariables.set('transaction_id', response.data.transaction_id);",
                  "        console.log('Transaction ID:', response.data.transaction_id);",
                  "        console.log('Checkout URL:', response.data.checkout_url);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payment_method\": \"chapa\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/storefront/orders/{{order_id}}/pay",
              "host": ["{{base_url}}"],
              "path": ["storefront", "orders", "{{order_id}}", "pay"]
            },
            "description": "Initialize Chapa payment for existing order"
          },
          "response": []
        },
        {
          "name": "Check Payment Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/storefront/orders/{{order_id}}/payment-status",
              "host": ["{{base_url}}"],
              "path": ["storefront", "orders", "{{order_id}}", "payment-status"]
            },
            "description": "Check current payment status of order"
          },
          "response": []
        }
      ]
    },
    {
      "name": "4. Admin - Payment Management",
      "item": [
        {
          "name": "Initialize Payment (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"order_id\": {{order_id}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/payments/initialize",
              "host": ["{{base_url}}"],
              "path": ["payments", "initialize"]
            }
          },
          "response": []
        },
        {
          "name": "Verify Payment",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/payments/{{transaction_id}}/verify",
              "host": ["{{base_url}}"],
              "path": ["payments", "{{transaction_id}}", "verify"]
            }
          },
          "response": []
        },
        {
          "name": "Get All Orders (Admin)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/orders",
              "host": ["{{base_url}}"],
              "path": ["orders"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "5. Webhook Testing",
      "item": [
        {
          "name": "Simulate Chapa Webhook - Success",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Chapa-Signature",
                "value": "test_signature_here",
                "description": "HMAC-SHA256 signature"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tx_ref\": \"{{transaction_id}}\",\n  \"status\": \"success\",\n  \"amount\": 1500.00,\n  \"currency\": \"ETB\",\n  \"payment_method\": \"telebirr\",\n  \"customer_email\": \"customer@example.com\",\n  \"customer_name\": \"Test Customer\",\n  \"created_at\": \"2026-03-10T10:30:00Z\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/payments/webhook/chapa",
              "host": ["{{base_url}}"],
              "path": ["payments", "webhook", "chapa"]
            },
            "description": "Simulate successful payment webhook from Chapa"
          },
          "response": []
        },
        {
          "name": "Simulate Chapa Webhook - Failed",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Chapa-Signature",
                "value": "test_signature_here"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tx_ref\": \"{{transaction_id}}\",\n  \"status\": \"failed\",\n  \"amount\": 1500.00,\n  \"currency\": \"ETB\",\n  \"payment_method\": \"telebirr\",\n  \"customer_email\": \"customer@example.com\",\n  \"failure_reason\": \"Insufficient funds\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/payments/webhook/chapa",
              "host": ["{{base_url}}"],
              "path": ["payments", "webhook", "chapa"]
            },
            "description": "Simulate failed payment webhook from Chapa"
          },
          "response": []
        }
      ]
    },
    {
      "name": "6. Health Check",
      "item": [
        {
          "name": "API Health Check",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
